public class GetById{{name}}Query({{idType}} id) : BaseQuery<{{name}}Dto?>
{
    
    /// <summary>
    ///     Gets or sets The Id of a single {{name}}.
    /// </summary>
    public {{idType}} Id { get; set; } = id;
}

internal sealed class GetById{{name}}QueryHandler(IInMemoryBus bus)
    : IBaseQueryHandler<GetById{{name}}Query, {{name}}Dto?>
{
    public async Task<{{name}}Dto?> Handle(
        GetById{{name}}Query request,
        CancellationToken cancellationToken)
